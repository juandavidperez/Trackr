# ── Database ──────────────────────────────────────────
# Dev: used by docker-compose for PostgreSQL container
# Prod: set these in Render environment variables (Supabase connection)
POSTGRES_DB=trackr
POSTGRES_USER=trackr
POSTGRES_PASSWORD=changeme

# ── Spring Datasource (backend) ──────────────────────
# Dev: docker-compose.yml overrides with jdbc:postgresql://db:5432/...
# Prod: set SPRING_DATASOURCE_URL to your Supabase connection string
#   Example: jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:6543/postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/trackr
SPRING_DATASOURCE_USERNAME=trackr
SPRING_DATASOURCE_PASSWORD=changeme

# ── JWT ──────────────────────────────────────────────
# IMPORTANT: Generate a secure secret for production
#   Example: openssl rand -base64 64
JWT_SECRET=changeme-generate-a-secure-256-bit-key
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ── CORS ─────────────────────────────────────────────
# Dev: http://localhost:4200
# Prod: your Netlify/Vercel frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ── Spring Profile ───────────────────────────────────
# dev | prod
SPRING_PROFILES_ACTIVE=dev
